# Copy to .env and fill in values before running any scripts or the server.

# Supabase Postgres — used read-only by the ML service
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Bearer token the Next.js app sends to this service (ML_API_KEY in apps/web)
ML_API_KEY=change-me-in-production

# EXPA OAuth — needed for peer LC backfill and diagnostic scripts.
# Provide either EXPA_ACCESS_TOKEN (pre-fetched) or the client credentials pair.
EXPA_CLIENT_ID=
EXPA_CLIENT_SECRET=
EXPA_ACCESS_TOKEN=
